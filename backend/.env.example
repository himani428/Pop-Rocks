PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret
# Comma separated list of allowed frontend origins (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173

# --- Owner email notifications ---
# The academy owner gets emailed whenever someone enrolls in a class, books an
# event, or submits the contact form. Without SMTP_* configured, notifications
# are just logged to the server console instead of sent (the site still works
# fine either way — you just won't get emails until this is set up).
OWNER_EMAIL=muskanwadhwani1324@gmail.com

# Easiest option: a Gmail address with an "App Password" (not your normal
# Gmail password). Turn on 2-Step Verification on the Gmail account, then
# create an App Password at https://myaccount.google.com/apppasswords and
# paste it below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=poprocksdance.website@gmail.com
SMTP_PASS=xylt cuaw lguy wpjo
